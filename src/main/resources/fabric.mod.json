{
	"schemaVersion": 1,
	"id": "${id}",
	"name": "${display_name}",
	"version": "${modversion}",
	"description": "${description}",
	"authors": [
		"${author}"
	],
	"contact": {
		"sources": "https://github.com/${github}/${name}"
	},
	"license": "${license}",
	"icon": "assets/${id}/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"${group}.${namespace}.${name}"
		]
	},
	"mixins": [
		"${id}.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.15.0",
		"minecraft": "${mc}",
		"java": ">=21"
	}
}